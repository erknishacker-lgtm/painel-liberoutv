# LIBEROU panel — upload de APK grande (~40MB+)
<IfModule mod_php.c>
  php_value upload_max_filesize 200M
  php_value post_max_size 220M
  php_value memory_limit 512M
  php_value max_execution_time 600
  php_flag display_errors Off
</IfModule>
<IfModule mod_php8.c>
  php_value upload_max_filesize 200M
  php_value post_max_size 220M
  php_value memory_limit 512M
  php_value max_execution_time 600
  php_flag display_errors Off
</IfModule>
